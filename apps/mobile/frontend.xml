        <MaterialCommunityIcons name="close" size={22} color="white" />
      </TouchableOpacity>

      <Text style={styles.statusLabel}>LISTENING</Text>
      
      <Text style={styles.transcriptHint}>
        {initialPromptHint || "Speak now..."}
