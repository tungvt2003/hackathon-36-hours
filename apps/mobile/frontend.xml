                >
                  <MaterialCommunityIcons name="chat-outline" size={22} color={theme.colors.textPrimary} />
                </TouchableOpacity>
              </View>
            </View>
          </View>

          {/* OTP CARD */}
          {showOtp && (
            <Animated.View
              style={[
                styles.otpCard,
                { opacity: otpOpacity, transform: [{ scale: otpScale }] },
              ]}
