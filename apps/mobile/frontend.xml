                  <Text style={styles.plateText}>{driver.plate}</Text>
                </View>
              </View>
              <View style={styles.driverActions}>
                <TouchableOpacity
                  style={styles.actionBtn}
                  accessibilityRole="button"
                  accessibilityLabel="Gọi tài xế"
