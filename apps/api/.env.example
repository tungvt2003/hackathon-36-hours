# ── Postgres ────────────────────────────────────────────────────
POSTGRES_USER=vmuser
POSTGRES_PASSWORD=vmpass
POSTGRES_DB=voice_mobility
# Port expose postgres ra host (dùng TablePlus / DBeaver connect)
DB_PORT=5432

# ── API (NestJS) ────────────────────────────────────────────────
# Khi chạy local: localhost; khi chạy docker-compose: host = "postgres"
DATABASE_URL="postgresql://vmuser:vmpass@localhost:5432/voice_mobility"

# Port bên trong container (NestJS listen) — không đổi
PORT=3000
# Port expose ra host (nginx proxy tới 127.0.0.1:APP_PORT)
APP_PORT=5757

# ── Providers ───────────────────────────────────────────────────
# "mock" = hardcode, không cần service ngoài
# "db"   = đọc từ Postgres (cần seed trước)
PROVIDER_STT=mock
PROVIDER_NLU=mock
PROVIDER_PLACES=db
PROVIDER_WEATHER=mock
PROVIDER_PARTNER=db

# ── Voice demo pipeline (optional) ───────────────────────────────
# VoiceModule also falls back to apps/deno-voice/.env for local demos.
NLU_MODE=llm
LLM_BASE_URL=http://localhost:20128/v1
LLM_MODEL=cx/gpt-5.5
LLM_API_KEY=
LLM_TIMEOUT_MS=30000
ENABLE_TTS=true
STT_PROVIDER=google
GOOGLE_STT_API_KEY=
VNPT_ACCESS_TOKEN=
VNPT_TOKEN_ID=
VNPT_TOKEN_KEY=
VNPT_BASE_URL=https://api.idg.vnpt.vn
TTS_VOICE=female_north
TTS_SPEED=1.0
