# ── Postgres (docker-compose đọc các biến POSTGRES_*) ──────────
POSTGRES_USER=vmuser
POSTGRES_PASSWORD=vmpass
POSTGRES_DB=voice_mobility
POSTGRES_PORT=5432

# ── API (NestJS đọc) ────────────────────────────────────────────
# DATABASE_URL phải khớp với POSTGRES_* ở trên
DATABASE_URL="postgresql://vmuser:vmpass@localhost:5432/voice_mobility"

PORT=3000

# "db"   = đọc từ Postgres (Places + Partners dùng data đã seed)
# "mock" = hardcode trong code, không cần DB
PROVIDER_STT=mock
PROVIDER_NLU=mock
PROVIDER_PLACES=db
PROVIDER_WEATHER=mock
PROVIDER_PARTNER=db
