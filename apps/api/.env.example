# ── Postgres ────────────────────────────────────────────────────
POSTGRES_USER=vmuser
POSTGRES_PASSWORD=vmpass
POSTGRES_DB=voice_mobility
POSTGRES_PORT=5432

# ── API (NestJS) ────────────────────────────────────────────────
# Khi chạy local: localhost; khi chạy docker-compose: host = "postgres"
DATABASE_URL="postgresql://vmuser:vmpass@localhost:5432/voice_mobility"

# Port bên trong container (NestJS listen) — không đổi
PORT=3000
# Port expose ra host (nginx proxy tới 127.0.0.1:APP_PORT)
APP_PORT=5757

# ── Providers ───────────────────────────────────────────────────
# "mock" = hardcode, không cần service ngoài
# "db"   = đọc từ Postgres (cần seed trước)
PROVIDER_STT=mock
PROVIDER_NLU=mock
PROVIDER_PLACES=db
PROVIDER_WEATHER=mock
PROVIDER_PARTNER=db
