<file path="prisma/schema.prisma">
// Prisma 7 schema

generator client {
  provider   = "prisma-client-js"
  output     = "../src/generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// Suara own tables — khong luu raw data cua doi tac
// ============================================================

model User {
  id           String                @id @default(cuid())
  name         String?
  phone        String?
  savedAddress String?
  orders       Order[]
  sessions     ConversationSession[]
  createdAt    DateTime              @default(now())
}

model Order {
  id                String       @id @default(cuid())
  userId            String?
  user              User?        @relation(fields: [userId], references: [id])
  type              String       // RIDE | FOOD
  origin            String?
  destination       String?
  deliveryAddress   String?
  partnerRestaurantId String?    // ID trong bang GrabRestaurant / BeRestaurant / ShopeeRestaurant
  restaurant        String?      // ten quan (display)
  items             Json?        // [{ menuItemId, name, qty, priceVnd }]
  status            String       // QUOTED|CONFIRMED|DRIVER_ASSIGNED|IN_TRANSIT|DELIVERED|CANCELLED
  partner           String?      // GRAB|BE|XANH_SM|SHOPEE
  partnerDriverId   String?      // ID trong bang GrabDriver / BeDriver / etc.
  driverName        String?      // cache ten tai xe de khoi query lai
  subtotalVnd       Int?
  deliveryFeeVnd    Int?
  discountVnd       Int?
  totalVnd          Int?
  etaMinutes        Int?
  responseText      String?
  accessibilityFlag Boolean      @default(false)
  createdAt         DateTime     @default(now())
  events            OrderEvent[]
  review            OrderReview?
}

model OrderEvent {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id])
  step      String
  payload   Json
  createdAt DateTime @default(now())
}

model OrderReview {
  id                String   @id @default(cuid())
  orderId           String   @unique
  order             Order    @relation(fields: [orderId], references: [id])
  restaurantRating  Int      // 1-5
  driverRating      Int      // 1-5
  voiceText         String?  // raw transcript cua user
  createdAt         DateTime @default(now())
}

model Place {
  id        String   @id @default(cuid())
  name      String
  address   String
  openHour  Int
  closeHour Int
  keywords  String[]
  createdAt DateTime @default(now())
}

model ConversationSession {
  id            String   @id @default(cuid())
  userId        String?
  user          User?    @relation(fields: [userId], references: [id])
  state         String   // COLLECTING|CONFIRMING|ORDERING|TRACKING|DONE
  intent        Json
  missingFields String[]
  orderId       String?
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

// ============================================================
// GRAB — simulate he thong rieng cua Grab
// ============================================================

model GrabRestaurant {
  id             String          @id @default(cuid())
  name           String
  address        String
  openHour       Int
  closeHour      Int
  cuisineType    String
  rating         Float           @default(4.5) // rating tu phia Grab (cold-start fallback)
  reviewCount    Int             @default(0)
  keywords       String[]
  deliveryFeeVnd Int             @default(15000)
