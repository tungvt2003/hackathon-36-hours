    return {
      partner: PartnerCode.BE,
      price: raw.data.price,
      etaMinutes: Math.ceil(raw.data.pickup_eta_sec / 60),
      driverName: raw.driver_info?.full_name,
      available: raw.data.is_available,
    };
  }
}
