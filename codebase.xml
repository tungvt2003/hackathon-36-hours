        options={{ presentation: 'transparentModal', animation: 'fade', headerShown: false }}
      />

      <Stack.Screen
        name="VoiceSpeaking"
        component={VoiceSpeakingScreen}
        options={{ presentation: 'transparentModal', animation: 'fade', headerShown: false }}
      />

