    : [];

  return {
    transcript,
    loading,
    orderResult,
    confirmResult,
    availableQuotes,
    setTranscript,
    handleSend,
    handleConfirm,
    handleReset,
    getPartnerLabel: (partner) => PARTNER_LABEL[partner],
  };
}
</file>

